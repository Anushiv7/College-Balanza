        "./client/src/hooks/useMobile.tsx",
        "./client/src/hooks/usePersistFn.ts",
        "./client/src/lib/trpc.ts",
        "./client/src/lib/utils.ts",
        "./client/src/pages/Compare.tsx",
        "./client/src/pages/ComponentShowcase.tsx",
        "./client/src/pages/Home.tsx",
        "./client/src/pages/Landing.tsx",
        "./client/src/pages/NotFound.tsx",
        "./client/src/pages/Privacy.tsx",
        "./shared/const.ts",
        "./shared/types.ts",
        "./shared/_core/errors.ts",
        "./server/db.ts",
        "./server/routers.ts",
        "./server/_core/constants.ts",
        "./server/_core/context.ts",
        "./server/_core/cookies.ts",
        "./server/_core/dev.ts",
        "./server/_core/env.ts",
        "./server/_core/index.ts",
        "./server/_core/llm.ts",
        "./server/_core/systemRouter.ts",
        "./server/_core/trpc.ts",
        "./server/_core/vite.ts",
        "./server/_core/middleware/anonymous.ts",
        "./server/_core/types/cookie.d.ts",
        "./server/routers/colleges.ts",
        "./server/types/express.d.ts",
        "./api/index.ts"
    ],
    "include": [
        "client/src/**/*",
        "shared/**/*",
        "server/**/*",
        "api/**/*"
    ],
    "exclude": [
        "node_modules",
        "build",
        "dist",
        "**/*.test.ts"
    ]
}
